{
  "metadata": [{
    "src": [{ "files": ["**/*.csproj"],
      "exclude": ["**/obj/**","**/bin/**","GenshinDataApp.Test/**"],
      "src": ".." }],
    "dest": "api"
  }],
  "build": {
    "content": [
      { "files": ["api/**.yml","api/index.md"] },
      { "files": ["docs/**.md","toc.yml","*.md"] }
    ],
    "dest": "_site",
    "template": ["default","modern"],
    "globalMetadata": {
      "_appTitle": "GenshinDataApp - Backend Documentation",
      "_appFooter": "Unofficial fan-made project. Genshin Impact is a trademark of HoYoverse Co., Ltd.",
      "_enableSearch": true
    }
  }
}
